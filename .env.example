# Configuración de la Base de Datos
DATABASE_URL=postgresql://tu_usuario:modd2026@localhost:5432/modd_db

# Clave secreta para JWT y sesiones (generar con: openssl rand -hex 32)
SECRET_KEY=tu-clave-secreta-muy-segura-aqui-cambiar-en-produccion

# Configuración del servidor
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Configuración de CORS (Frontend URLs permitidas)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Credenciales de administrador por defecto (SOLO PARA DESARROLLO)
ADMIN_EMAIL=admin@unison.mx
ADMIN_PASSWORD=modd2026

# Configuración de Email (para notificaciones futuras)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@unison.mx
SMTP_PASSWORD=tu-contraseña-de-aplicacion

# Timezone
TIMEZONE=America/Hermosillo
